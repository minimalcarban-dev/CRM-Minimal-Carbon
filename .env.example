# --- Chat Feature Configuration ---
# Max upload size per attachment in MB (validated server + client)
CHAT_MAX_UPLOAD_MB=10
# Comma-separated whitelist of allowed MIME types
CHAT_ALLOWED_MIMES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain
# Per-admin per-channel message limit per minute (custom middleware)
CHAT_RATE_LIMIT=20

# --- Real-time / Pusher Configuration ---
