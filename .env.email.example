##############################################################################
# GMAIL CONFIGURATION
# Get credentials from: https://console.cloud.google.com/apis/credentials
##############################################################################

# Gmail OAuth2 Credentials
GMAIL_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_APP_NAME="CRM Email System"
GMAIL_REDIRECT_URI=https://your-domain.com/admin/email/oauth/callback
GMAIL_HTTP_VERIFY=

# Storage Configuration for Attachments
ATTACHMENT_DISK=local
ATTACHMENT_PATH=emails

# Sync Configuration
EMAIL_SYNC_INTERVAL=5  # minutes between syncs
EMAIL_SYNC_BATCH_SIZE=50  # max emails fetched per sync run
EMAIL_INITIAL_SYNC_LIMIT=20
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=2  # seconds

# Token Encryption
GMAIL_TOKEN_CIPHER=AES-256-GCM

# Audit Logging
EMAIL_AUDIT_RETENTION=90  # days

##############################################################################
# Note: Add to main .env file. Never commit secrets.
##############################################################################
